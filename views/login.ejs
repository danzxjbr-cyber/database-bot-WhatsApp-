<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Danzx Official</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#FFDE4D] min-h-screen flex items-center justify-center p-6 font-mono">
    <div class="bg-white border-4 border-black p-8 max-w-md w-full shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]">
        <h1 class="text-3xl font-extrabold uppercase mb-2 tracking-tight">Danzx Official</h1>
        <p class="text-sm font-bold text-gray-700 mb-6">Database Security Panel</p>
        
        <% if (error) { %>
            <div class="bg-[#FF6B6B] border-2 border-black p-3 mb-4 font-bold text-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
                <%= error %>
            </div>
        <% } %>

        <form action="/login" method="POST" class="space-y-4">
            <div>
                <label class="block font-black uppercase text-sm mb-1">Username</label>
                <input type="text" name="username" required class="w-full p-3 border-4 border-black font-bold focus:outline-none focus:bg-[#A3FFD6] transition">
            </div>
            <div>
                <label class="block font-black uppercase text-sm mb-1">Password</label>
                <input type="password" name="password" required class="w-full p-3 border-4 border-black font-bold focus:outline-none focus:bg-[#A3FFD6] transition">
            </div>
            <button type="submit" class="w-full bg-[#A3FFD6] hover:bg-[#85e0b9] border-4 border-black p-3 font-black uppercase text-lg shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] active:translate-x-1 active:translate-y-1 active:shadow-none transition-all">
                Masuk Panel
            </button>
        </form>

        <hr class="border-2 border-black my-6">
        <div class="text-center">
            <a href="https://t.me/Danzx_JBR" target="_blank" class="inline-block bg-[#98D8EF] hover:bg-[#7cb9cf] border-4 border-black px-4 py-2 font-black text-sm shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
                Hubungi Telegram Danzx_JBR
            </a>
        </div>
    </div>
</body>
</html>
