<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Danzx Official</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#FFBE98] min-h-screen p-6 font-mono">
    <div class="max-w-5xl mx-auto space-y-6">
        
        <!-- Header -->
        <header class="bg-white border-4 border-black p-6 flex flex-col md:flex-row md:items-center md:justify-between shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]">
            <div>
                <h1 class="text-4xl font-black uppercase tracking-tight">Danzx Official</h1>
                <p class="font-bold text-gray-700">Database Security Management Panel</p>
            </div>
            <div class="mt-4 md:mt-0 flex gap-2">
                <a href="https://t.me/Danzx_JBR" target="_blank" class="bg-[#98D8EF] border-4 border-black px-4 py-2 font-black uppercase text-sm shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:bg-[#7cb9cf]">Telegram</a>
                <a href="/login" class="bg-[#FF6B6B] border-4 border-black px-4 py-2 font-black uppercase text-sm shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:bg-red-400">Logout</a>
            </div>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Form Input -->
            <div class="bg-white border-4 border-black p-6 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] h-fit">
                <h2 class="text-2xl font-black uppercase mb-4 border-b-4 border-black pb-2">Tambah Nomor</h2>
                <form action="/add-user" method="POST" class="space-y-4">
                    <div>
                        <label class="block font-black uppercase text-xs mb-1">Nomor WhatsApp (62xxx)</label>
                        <input type="text" name="phone" placeholder="628123456789" required class="w-full p-2 border-4 border-black font-bold focus:outline-none focus:bg-[#A3FFD6]">
                    </div>
                    <div>
                        <label class="block font-black uppercase text-xs mb-1">Nama Pemilik</label>
                        <input type="text" name="name" placeholder="Contoh: Danzx User" required class="w-full p-2 border-4 border-black font-bold focus:outline-none focus:bg-[#A3FFD6]">
                    </div>
                    <div>
                        <label class="block font-black uppercase text-xs mb-1">Status Keamanan</label>
                        <select name="status" class="w-full p-2 border-4 border-black font-bold focus:outline-none bg-white">
                            <option value="Secure">Secure</option>
                            <option value="Banned">Banned/Suspended</option>
                            <option value="Monitoring">Monitoring</option>
                        </select>
                    </div>
                    <button type="submit" class="w-full bg-[#A3FFD6] border-4 border-black p-2 font-black uppercase shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] active:translate-x-0.5 active:translate-y-0.5 active:shadow-none transition-all">
                        Simpan ke DB
                    </button>
                </form>
            </div>

            <!-- Tabel Data -->
            <div class="bg-white border-4 border-black p-6 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] md:col-span-2 overflow-x-auto">
                <h2 class="text-2xl font-black uppercase mb-4 border-b-4 border-black pb-2">Daftar Database</h2>
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b-4 border-black bg-gray-100">
                            <th class="p-2 font-black uppercase text-sm">Nama</th>
                            <th class="p-2 font-black uppercase text-sm">No WA</th>
                            <th class="p-2 font-black uppercase text-sm">Status</th>
                            <th class="p-2 font-black uppercase text-sm text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (users.length === 0) { %>
                            <tr>
                                <td colspan="4" class="p-4 font-bold text-center text-gray-500">Database Kosong</td>
                            </tr>
                        <% } %>
                        <% users.forEach(user => { %>
                            <tr class="border-b-2 border-black hover:bg-yellow-50">
                                <td class="p-2 font-bold"><%= user.name %></td>
                                <td class="p-2 font-mono text-sm"><%= user.phone %></td>
                                <td class="p-2">
                                    <span class="px-2 py-0.5 border-2 border-black text-xs font-black uppercase 
                                        <%= user.status === 'Secure' ? 'bg-[#A3FFD6]' : user.status === 'Banned' ? 'bg-[#FF6B6B]' : 'bg-[#98D8EF]' %>">
                                        <%= user.status %>
                                    </span>
                                </td>
                                <td class="p-2 text-center">
                                    <a href="/delete-user/<%= user.phone %>" class="bg-[#FF6B6B] border-2 border-black px-2 py-1 text-xs font-black uppercase shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:bg-red-400">
                                        Hapus
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</body>
</html>
